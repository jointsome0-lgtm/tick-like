    {"file": "v2-valid.json", "read_as": 2, "expect": "ok", "findings": []},
    {"file": "v2-unknown-fields.json", "read_as": 2, "expect": "ok", "findings": [], "preserves_unknown_fields": true},
    {"file": "v2-invalid-paths.json", "read_as": 2, "expect": "degraded", "findings": ["invalid-entry", "invalid-path", "outside-root"]},
    {"file": "v2-duplicate-refs.json", "read_as": 2, "expect": "rejected", "findings": ["duplicate-id", "duplicate-path"]},
    {"file": "v2-missing-identity.json", "read_as": 2, "expect": "rejected", "findings": ["missing-identity"]},
    {"file": "v99-unsupported-version.json", "read_as": null, "expect": "rejected", "findings": ["unsupported-version"]}
